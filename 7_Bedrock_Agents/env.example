# AWS region — used by Terraform and the app
# If not set, defaults to us-east-1
AWS_REGION=us-east-1

# AWS credentials are NOT required here if you are authenticated locally
# via `aws configure`, AWS SSO, or an IAM instance/task role.
# Only set these if you need to override the default credential chain.
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key
