# API Gateway invoke URL — from the AWS Console after deployment
# HTTP API format (no stage name in path):
#   https://<api-id>.execute-api.<region>.amazonaws.com/chat
VITE_API_URL=https://your-api-id.execute-api.us-east-1.amazonaws.com/chat

# Used by the frontend deploy script (build + S3 website upload)
REGION=us-east-1
BUCKET=rag-kb-frontend-ACCOUNT_ID
